# ═══════════════════════════════════════════════════════════════════════════════
# DualAgentHedgeSystem — Environment Configuration
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend ───────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3003
JWT_SECRET_KEY=your-32-char-secret-key-here!!
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://dual-agent-hedge-system-nxcnqs6ue-rodney-mitchells-projects.vercel.app,http://localhost:5173

# ── OAuth (optional — for social login) ───────────────────────────────────────
# Create apps at:
#   Google: https://console.cloud.google.com/apis/credentials
#   GitHub: https://github.com/settings/developers
#   Facebook: https://developers.facebook.com/apps
# Set callback URLs to: http://localhost:3003/api/auth/oauth/{provider}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── Trading ───────────────────────────────────────────────────────────────────
PAPER_TRADING=true
DEFAULT_TRADING_USER=admin

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Exchange API Keys ─────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Vercel (optional — for CI/CD deployment) ──────────────────────────────────
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
