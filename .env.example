# ═══════════════════════════════════════════════════════════════════════════════
# DualAgentHedgeSystem — Environment Configuration
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── GitHub OAuth (configured in Supabase Auth > Providers) ────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
# Set callback URL to: https://your-project-ref.supabase.co/auth/v1/callback
GITHUB_CLIENT_ID=your-github-oauth-app-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret

# ── Vercel ────────────────────────────────────────────────────────────────────
# Get from Vercel dashboard: Project Settings > General
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_TOKEN=your-vercel-token

# ── Backend ───────────────────────────────────────────────────────────────────
# JWT secret for legacy auth (not used with Supabase Auth, but keep for safety)
JWT_SECRET_KEY=your-32-char-secret-key-here!!
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ── Trading ───────────────────────────────────────────────────────────────────
PAPER_TRADING=true
DEFAULT_TRADING_USER=admin

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Exchange API Keys (encrypted at rest in Supabase) ─────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are injected at build time by Vercel or your CI/CD
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
