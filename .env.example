# ============================================================
# HedgeSwarm Full-Stack Environment Configuration
# Copy to .env and fill in your credentials
# ============================================================

# ── System ──────────────────────────────────────────────────
PAPER_TRADING=true
LOG_LEVEL=INFO

# ── Authentication ──────────────────────────────────────────
# Change these in production!
ADMIN_USER=admin
ADMIN_PASSWORD=admin
JWT_SECRET_KEY=change-me-in-production-to-a-random-32-char-string

# ── CORS ────────────────────────────────────────────────────
# Comma-separated allowed origins for the API (production: your domain only)
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── LLM Providers ───────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=

# ── Exchange Credentials ────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_TESTNET=true

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Defense Swarm ───────────────────────────────────────────
DEFENSE_BACKUP_API_KEYS=

# ── Arbitrage Module ────────────────────────────────────────
ARB_MIN_PROFIT_PCT=0.35
ARB_MAX_TRADE_USDT=5000.0
ARB_SCAN_INTERVAL_S=3.0
ARB_CROSS_EXCHANGE=true
ARB_SPOT_PERP=true
ARB_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT

# ── Social / On-Chain ───────────────────────────────────────
TWITTER_BEARER_TOKEN=
LUNARCRUSH_API_KEY=
GLASSNODE_API_KEY=
COINGLASS_API_KEY=
